<UserControl x:Class="Patient_Report.ReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Patient_Report"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    <Grid>
        <Button Name="addDQM_btn" Width="150" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="10,10,0,0" Click="AddDQM_btn_Click" Content="Add DQM"></Button>
        <ScrollViewer Width="500" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Name="params_sp" Margin="5"></StackPanel>
        </ScrollViewer>
        <Button Name="Print_btn" Width="150" Height="40" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,10,10" Click="Print_btn_Click" Content="Print"></Button>
    </Grid>
</UserControl>
